# Application metadata
APP_NAME=Reliable AI Agent API
APP_ENV=development
APP_DEBUG=false

# API server binding
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of allowed CORS origins (e.g. frontend URLs)
CORS_ORIGINS=http://localhost:5173

# Redis state/checkpoint storage URL
REDIS_URL=redis://redis:6379/0
REDIS_TTL_SECONDS=86400

# LLM provider keys
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Web search provider key
TAVILY_API_KEY=your_tavily_api_key

# Model selection and fallback chain
PRIMARY_MODEL=gpt-4o
FALLBACK_MODEL_OPENAI=gpt-4o-mini
FALLBACK_MODEL_ANTHROPIC=claude-3-5-sonnet-latest

# Embedding model for vector memory retrieval
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
